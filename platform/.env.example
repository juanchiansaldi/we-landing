# ─── Base de datos (Supabase Postgres) ───
# En Supabase: Project Settings → Database → Connection string
# Usá la "Connection pooling" (puerto 6543) para DATABASE_URL
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# y la conexión directa (puerto 5432) para migraciones
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── Supabase (Auth + Storage) ───
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="..."
SUPABASE_SERVICE_ROLE_KEY="..."   # solo del lado servidor

# ─── Mercado Pago ───
# Credenciales: developers.mercadopago.com → Tus integraciones → Credenciales
MP_ACCESS_TOKEN="APP_USR-..."             # privada (servidor)
NEXT_PUBLIC_MP_PUBLIC_KEY="APP_USR-..."   # pública (checkout)
MP_WEBHOOK_SECRET="..."                   # para validar webhooks

# ─── App ───
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
DEFAULT_STORE_SLUG="we"
