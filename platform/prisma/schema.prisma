// We · Cava — Esquema de la base de datos
// Single-store hoy (una fila en Store), pero TODO está scopeado por `storeId`
// para poder pasar a multi-tenant (revender) sin rehacer el modelo.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Supabase: conexión directa para migraciones
}

// ───────────── Tienda (tenant) ─────────────
model Store {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  domain    String?  @unique
  whatsapp  String?
  alias     String? // alias de transferencia
  titular   String?
  shipNote  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  users         User[]
  categories    Category[]
  products      Product[]
  customers     Customer[]
  orders        Order[]
  plans         Plan[]
  subscriptions Subscription[]
  coupons       Coupon[]
  addresses     Address[]
  suppliers     Supplier[]
  sales         Sale[]
  stockMoves    StockMovement[]
  purchases     Purchase[]
  cashSessions  CashSession[]
  auditLogs     AuditLog[]
  posUsers      PosUser[]
}

enum Role {
  OWNER
  ADMIN
  STAFF
}

// Usuarios del panel (la auth real la maneja Supabase; acá guardamos rol + tienda)
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(STAFF)
  authId    String?  @unique // id del usuario en Supabase Auth
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  createdAt DateTime @default(now())
}

// ───────────── Catálogo ─────────────
model Category {
  id      String @id @default(cuid())
  storeId String
  store   Store  @relation(fields: [storeId], references: [id])
  name    String
  slug    String
  order   Int    @default(0)

  products Product[]

  @@unique([storeId, slug])
}

model Product {
  id         String    @id @default(cuid())
  storeId    String
  store      Store     @relation(fields: [storeId], references: [id])
  name       String
  slug       String
  brand      String?
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  price      Int // en centavos? -> usamos pesos enteros (sin decimales en ARS)
  promoPrice Int?
  shortDesc  String? // descripción corta (tarjeta)
  description String?  @db.Text // descripción larga (ficha)
  stock      Int       @default(0)
  isNew      Boolean   @default(false)
  active     Boolean   @default(true)
  meta       Json? // ficha técnica: [{ k, v }]

  // ───── Campos POS (gestión del local). Todo opcional para no romper la tienda. ─────
  sku          String? // código interno (ej. WE-000123)
  quickCode    String? // código rápido para tipear en la caja (ej. 170 = Coca)
  barcode      String? // código de barras de fábrica (EAN-13), si tiene
  cost         Int? // costo en pesos (para ganancia real)
  priceCase    Int? // precio por caja cerrada
  unitsPerCase Int     @default(6)
  stockMin     Int     @default(0)
  highValue    Boolean @default(false) // alto valor (guarda, destilados importados)
  varietal     String?
  vintage      Int? // añada (año)
  abv          Float? // % alcohol
  volumeMl     Int?    @default(750)
  isKit        Boolean @default(false)
  margin       Int? // % de margen para combos (precio = costo combinado * (1 + margin/100))
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id])

  images        ProductImage[]
  orderItems    OrderItem[]
  saleItems     SaleItem[]
  stockMoves    StockMovement[]
  purchaseItems PurchaseItem[]
  kitOf         KitItem[] @relation("kitParent")
  kitInside     KitItem[] @relation("kitComponent")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, slug])
  @@unique([storeId, sku])
  @@unique([storeId, quickCode])
  @@index([storeId, categoryId])
  @@index([storeId, barcode])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  order     Int     @default(0)
}

// ───────────── Clientes / Pedidos ─────────────
model Customer {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  email     String
  name      String?
  phone     String?
  authId    String? // id del usuario en Supabase Auth (link de la cuenta)
  // ───── POS / cuenta corriente ─────
  vip       Boolean  @default(false)
  cuit      String?
  ccBalance Int      @default(0) // saldo cuenta corriente en pesos (+ = debe)
  createdAt DateTime @default(now())

  orders        Order[]
  subscriptions Subscription[]
  addresses     Address[]
  sales         Sale[]
  ledger        CustomerLedger[]

  @@unique([storeId, email])
  @@index([authId])
}

// Direcciones de envío del cliente
model Address {
  id         String   @id @default(cuid())
  storeId    String
  store      Store    @relation(fields: [storeId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label      String? // "Casa", "Trabajo"
  recipient  String // quién recibe
  phone      String?
  street     String
  number     String?
  city       String
  province   String
  zip        String?
  notes      String? // entre calles, depto, referencia
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([customerId])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Order {
  id            String        @id @default(cuid())
  storeId       String
  store         Store         @relation(fields: [storeId], references: [id])
  customerId    String?
  customer      Customer?     @relation(fields: [customerId], references: [id])
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod String? // mercadopago | transferencia | whatsapp
  mpPaymentId   String?
  subtotal      Int
  shipping      Int           @default(0)
  total         Int
  notes         String?
  shipAddress   Json? // snapshot de la dirección de envío al momento de la compra
  giftNote      String? // mensaje de regalo opcional
  receiptUrl    String? // comprobante de transferencia subido por el admin
  paidAt        DateTime? // cuándo se marcó como pagado
  items         OrderItem[]
  createdAt     DateTime      @default(now())

  @@index([storeId, status])
  @@index([storeId, paymentStatus])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  name      String // snapshot del nombre al momento de la compra
  price     Int // snapshot del precio
  qty       Int
}

// ───────────── Suscripciones (Club We) ─────────────
model Plan {
  id       String  @id @default(cuid())
  storeId  String
  store    Store   @relation(fields: [storeId], references: [id])
  slug     String
  name     String
  price    Int
  interval String  @default("monthly")
  features Json? // ["2 botellas...", "10% off..."]
  active   Boolean @default(true)

  subscriptions Subscription[]

  @@unique([storeId, slug])
}

enum SubStatus {
  PENDING
  ACTIVE
  PAUSED
  CANCELLED
}

model Subscription {
  id              String    @id @default(cuid())
  storeId         String
  store           Store     @relation(fields: [storeId], references: [id])
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id])
  planId          String
  plan            Plan      @relation(fields: [planId], references: [id])
  status          SubStatus @default(PENDING)
  mpPreapprovalId String? // id de la suscripción en Mercado Pago (débito automático)
  startedAt       DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime  @default(now())

  @@index([storeId, status])
}

// ───────────── Cupones / Promos ─────────────
enum CouponType {
  PERCENT
  FIXED
}

model Coupon {
  id        String     @id @default(cuid())
  storeId   String
  store     Store      @relation(fields: [storeId], references: [id])
  code      String
  type      CouponType @default(PERCENT)
  value     Int
  active    Boolean    @default(true)
  expiresAt DateTime?

  @@unique([storeId, code])
}

model Newsletter {
  id        String   @id @default(cuid())
  storeId   String
  email     String
  createdAt DateTime @default(now())

  @@unique([storeId, email])
}

// ═══════════════ POS · Gestión del local ═══════════════

enum SaleUnit {
  BOTELLA
  CAJA
}

enum PayMethod {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
  CUENTA_CORRIENTE
  MIXTO
}

enum MoveType {
  INGRESO
  EGRESO
  AJUSTE
}

enum CashStatus {
  ABIERTA
  CERRADA
}

enum LedgerType {
  CARGO
  PAGO
}

enum PosRole {
  ADMIN
  VENDEDOR
}

model Supplier {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  nombre    String
  cuit      String?
  contacto  String?
  telefono  String?
  email     String?
  notas     String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  productos Product[]
  purchases Purchase[]

  @@index([storeId])
}

model PosUser {
  id           String   @id @default(cuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id])
  username     String
  nombre       String
  passwordHash String
  role         PosRole  @default(VENDEDOR)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())

  sales Sale[]

  @@unique([storeId, username])
}

model Sale {
  id            String       @id @default(cuid())
  storeId       String
  store         Store        @relation(fields: [storeId], references: [id])
  posUserId     String?
  posUser       PosUser?     @relation(fields: [posUserId], references: [id])
  customerId    String?
  customer      Customer?    @relation(fields: [customerId], references: [id])
  cashSessionId String?
  cashSession   CashSession? @relation(fields: [cashSessionId], references: [id])
  subtotal      Int
  discount      Int          @default(0)
  total         Int
  payMethod     PayMethod    @default(EFECTIVO)
  payCash       Int          @default(0)
  payCard       Int          @default(0)
  payTransfer   Int          @default(0)
  payAccount    Int          @default(0)
  note          String?
  voided        Boolean      @default(false)
  createdAt     DateTime     @default(now())

  items SaleItem[]

  @@index([storeId, createdAt])
}

model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  name      String
  unit      SaleUnit @default(BOTELLA)
  qty       Int
  unitPrice Int
  unitCost  Int      @default(0)
  subtotal  Int
}

model StockMovement {
  id             String   @id @default(cuid())
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id])
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  type           MoveType
  qty            Int // con signo (botellas)
  reason         String // venta|compra|ajuste|anulacion|merma|kit
  refType        String?
  refId          String?
  posUserId      String?
  resultingStock Int
  createdAt      DateTime @default(now())

  @@index([storeId, productId])
}

model Purchase {
  id            String   @id @default(cuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id])
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  invoiceNumber String?
  total         Int      @default(0)
  note          String?
  createdAt     DateTime @default(now())

  items PurchaseItem[]

  @@index([storeId, createdAt])
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  String?
  product    Product? @relation(fields: [productId], references: [id])
  qty        Int
  unitCost   Int
  subtotal   Int
}

model CashSession {
  id            String     @id @default(cuid())
  storeId       String
  store         Store      @relation(fields: [storeId], references: [id])
  openedById    String?
  openingAmount Int        @default(0)
  openedAt      DateTime   @default(now())
  closedAt      DateTime?
  declaredAmount Int?
  countedAmount Int?
  difference    Int?
  status        CashStatus @default(ABIERTA)
  note          String?

  sales Sale[]

  @@index([storeId, status])
}

model KitItem {
  id          String  @id @default(cuid())
  kitId       String
  kit         Product @relation("kitParent", fields: [kitId], references: [id], onDelete: Cascade)
  componentId String
  component   Product @relation("kitComponent", fields: [componentId], references: [id])
  qty         Int     @default(1)
}

model CustomerLedger {
  id               String     @id @default(cuid())
  customerId       String
  customer         Customer   @relation(fields: [customerId], references: [id])
  type             LedgerType
  amount           Int
  refSaleId        String?
  resultingBalance Int
  note             String?
  createdAt        DateTime   @default(now())

  @@index([customerId])
}

model AuditLog {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  posUserId String?
  action    String
  entity    String?
  entityId  String?
  detail    String?
  createdAt DateTime @default(now())

  @@index([storeId, createdAt])
}
