// We · Cava — Esquema de la base de datos
// Single-store hoy (una fila en Store), pero TODO está scopeado por `storeId`
// para poder pasar a multi-tenant (revender) sin rehacer el modelo.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Supabase: conexión directa para migraciones
}

// ───────────── Tienda (tenant) ─────────────
model Store {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  domain    String?  @unique
  whatsapp  String?
  alias     String? // alias de transferencia
  titular   String?
  shipNote  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  users         User[]
  categories    Category[]
  products      Product[]
  customers     Customer[]
  orders        Order[]
  plans         Plan[]
  subscriptions Subscription[]
  coupons       Coupon[]
}

enum Role {
  OWNER
  ADMIN
  STAFF
}

// Usuarios del panel (la auth real la maneja Supabase; acá guardamos rol + tienda)
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(STAFF)
  authId    String?  @unique // id del usuario en Supabase Auth
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  createdAt DateTime @default(now())
}

// ───────────── Catálogo ─────────────
model Category {
  id      String @id @default(cuid())
  storeId String
  store   Store  @relation(fields: [storeId], references: [id])
  name    String
  slug    String
  order   Int    @default(0)

  products Product[]

  @@unique([storeId, slug])
}

model Product {
  id         String    @id @default(cuid())
  storeId    String
  store      Store     @relation(fields: [storeId], references: [id])
  name       String
  slug       String
  brand      String?
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  price      Int // en centavos? -> usamos pesos enteros (sin decimales en ARS)
  promoPrice Int?
  shortDesc  String? // descripción corta (tarjeta)
  description String?  @db.Text // descripción larga (ficha)
  stock      Int       @default(0)
  isNew      Boolean   @default(false)
  active     Boolean   @default(true)
  meta       Json? // ficha técnica: [{ k, v }]

  images     ProductImage[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, slug])
  @@index([storeId, categoryId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  order     Int     @default(0)
}

// ───────────── Clientes / Pedidos ─────────────
model Customer {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  email     String
  name      String?
  phone     String?
  createdAt DateTime @default(now())

  orders        Order[]
  subscriptions Subscription[]

  @@unique([storeId, email])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Order {
  id            String        @id @default(cuid())
  storeId       String
  store         Store         @relation(fields: [storeId], references: [id])
  customerId    String?
  customer      Customer?     @relation(fields: [customerId], references: [id])
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod String? // mercadopago | transferencia | whatsapp
  mpPaymentId   String?
  subtotal      Int
  shipping      Int           @default(0)
  total         Int
  notes         String?
  items         OrderItem[]
  createdAt     DateTime      @default(now())

  @@index([storeId, status])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  name      String // snapshot del nombre al momento de la compra
  price     Int // snapshot del precio
  qty       Int
}

// ───────────── Suscripciones (Club We) ─────────────
model Plan {
  id       String  @id @default(cuid())
  storeId  String
  store    Store   @relation(fields: [storeId], references: [id])
  slug     String
  name     String
  price    Int
  interval String  @default("monthly")
  features Json? // ["2 botellas...", "10% off..."]
  active   Boolean @default(true)

  subscriptions Subscription[]

  @@unique([storeId, slug])
}

enum SubStatus {
  PENDING
  ACTIVE
  PAUSED
  CANCELLED
}

model Subscription {
  id              String    @id @default(cuid())
  storeId         String
  store           Store     @relation(fields: [storeId], references: [id])
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id])
  planId          String
  plan            Plan      @relation(fields: [planId], references: [id])
  status          SubStatus @default(PENDING)
  mpPreapprovalId String? // id de la suscripción en Mercado Pago (débito automático)
  startedAt       DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime  @default(now())

  @@index([storeId, status])
}

// ───────────── Cupones / Promos ─────────────
enum CouponType {
  PERCENT
  FIXED
}

model Coupon {
  id        String     @id @default(cuid())
  storeId   String
  store     Store      @relation(fields: [storeId], references: [id])
  code      String
  type      CouponType @default(PERCENT)
  value     Int
  active    Boolean    @default(true)
  expiresAt DateTime?

  @@unique([storeId, code])
}
